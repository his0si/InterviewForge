# interviewforge DB. 컨테이너 실행이면 host.docker.internal, 호스트 venv 면 localhost.
DATABASE_URL=postgresql://interviewforge:life0635@host.docker.internal:5434/interviewforge

# 사람인 오픈 API 키 (https://oapi.saramin.co.kr 발급). 비우면 사람인은 건너뜀.
SARAMIN_API_KEY=

# 수집 키워드(콤마 구분)
KEYWORDS=개발자,백엔드,프론트엔드,데이터

# 매일 자동 실행 시각(KST) + 어댑터별 상한
CRAWL_HOUR=5
CRAWL_MINUTE=0
MAX_PER_SOURCE=300
TZ=Asia/Seoul

# 로컬 LLM(Ollama) 요약. 컨테이너=host.docker.internal, 호스트 venv=localhost.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=exaone3.5:latest
SUMMARY_LIMIT=120
