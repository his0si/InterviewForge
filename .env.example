# 배포 설정 "템플릿" (git에 커밋됨).
# 복사해서 실제 값이 든 .env 를 만든다:  cp .env.example .env
# setup-ssl.sh 가 .env 의 값으로 ZeroSSL 인증서를 발급/갱신한다.

# 인증서를 발급할 도메인
DOMAIN_NAME=interviewforge.kro.kr

# ZeroSSL 갱신 알림을 받을 이메일 (본인 이메일로 교체)
SSL_EMAIL=you@example.com

# Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# ── 인증/DB/메일 ──────────────────────────────────────────────────────────
# 인증 링크/리다이렉트의 베이스 URL (운영 도메인)
APP_URL=https://interviewforge.kro.kr

# 컨테이너 → 호스트의 interviewforge 전용 Postgres 클러스터(포트 5434, db/setup-cluster.sh 로 생성).
DATABASE_URL=postgresql://interviewforge:CHANGE_ME@host.docker.internal:5434/interviewforge

# JWT 서명 키 — 길고 랜덤하게. 생성:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_RANDOM_64_HEX

# Gmail SMTP (구글 계정 > 보안 > 앱 비밀번호 16자리)
SMTP_USER=you@gmail.com
SMTP_PASS=CHANGE_ME_GMAIL_APP_PASSWORD
SMTP_FROM=you@gmail.com

# 로컬 LLM(Ollama). 컨테이너=host.docker.internal, 호스트 직접 실행=localhost.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=exaone3.5:latest
OLLAMA_EMBED_MODEL=bge-m3:latest
